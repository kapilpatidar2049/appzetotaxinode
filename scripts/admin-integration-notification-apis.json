        "payment_option": "cash,card,wallet",
        "enable_paystack": "0",
        "paystack_environment": "test",
        "paystack_test_secret_key": "",
        "paystack_production_secret_key": "",
        "paystack_test_publishable_key": "",
        "paystack_production_publishable_key": "",
        "enable_cashfree": "0",
        "cash_free_environment": "test",
        "cash_free_secret_key": "",
        "cash_free_production_secret_key": "",
        "cash_free_app_id": "",
        "cash_free_production_app_id": "",
        "enable_mercadopago": "0",
        "mercadopago_environment": "test",
        "mercadopago_test_public_key": "",
        "mercadopago_live_public_key": "",
        "mercadopago_test_access_token": "",
        "mercadopago_live_access_token": "",
        "enable_stripe": "1",
        "stripe_environment": "test",
        "stripe_test_secret_key": "sk_test_xxx",
        "stripe_live_secret_key": "sk_live_xxx",
        "stripe_test_publishable_key": "pk_test_xxx",
        "stripe_live_publishable_key": "pk_live_xxx",
        "enable_stripe_authorization": "0",
        "enable_xendit": "0",
        "xendi_pay_environment": "test",
        "xendi_pay_test_api_key": "",
        "xendit_pay_live_api_key": "",
        "enable_flutter_wave": "0",
        "flutter_wave_environment": "test",
        "flutter_wave_test_secret_key": "",
        "flutter_wave_production_secret_key": "",
        "enable_razor_pay": "0",
        "razor_pay_environment": "test",
        "razor_pay_test_api_key": "",
        "razor_pay_live_api_key": "",
        "razor_pay_secrect_key": "",
        "razor_pay_test_secrect_key": "",
        "enable_khalti_pay": "0",
        "khalti_pay_environment": "test",
        "khalti_pay_test_api_key": "",
        "khalti_pay_live_api_key": "",
        "enable_flexpaie": "0",
        "flexpaie_environment": "test",
        "flexpaie_test_bearer_token": "",
        "flexpaie_production_bearer_token": "",
        "enable_openpix": "0",
        "openpix_environment": "test",
        "openpix_test_api_key": "",
        "openpix_live_api_key": "",
