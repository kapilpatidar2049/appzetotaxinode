{
  "info": {
    "description": "Admin integration settings + notification channel APIs — request/response shapes for Postman or frontend.",
    "auth_header": "Authorization: Bearer <admin JWT from POST /api/v1/admin/login>",
    "content_type": "application/json",
    "integration_base": "/api/v1/admin/integration-settings",
    "notification_channels_base": "/api/v1/admin/notification-channels"
  },
  "integration_settings": {
    "payment_gateways_list": {
      "method": "GET",
      "path": "/api/v1/admin/integration-settings/payment-gateways",
      "query": {
        "enabled": "optional: \"1\" | \"true\" to filter enabled only; \"0\" | \"false\" for disabled"
      },
      "response_example": {
        "success": true,
        "message": "success",
        "data": {
          "results": [
            {
              "_id": "507f1f77bcf86cd799439011",
              "gateway": "Stripe",
              "slug": "stripe",
              "image": "",
              "order": 0,
              "enabled": true,
              "for_ride": true,
              "for_wallet": true,
              "supported_countries": ["IN"],
              "supported_currencies": ["INR"],
              "createdAt": "2026-01-01T00:00:00.000Z",
              "updatedAt": "2026-01-01T00:00:00.000Z"
            }
          ],
          "total": 1
        }
      }
    },
    "payment_gateways_patch": {
      "method": "PATCH",
      "path": "/api/v1/admin/integration-settings/payment-gateways/:id",
      "path_params": { "id": "MongoDB ObjectId of PaymentGateway document" },
      "body_example": {
        "gateway": "Stripe",
        "slug": "stripe",
        "image": "https://example.com/stripe.png",
        "order": 0,
        "enabled": true,
        "for_ride": true,
        "for_wallet": true,
        "supported_countries": ["IN", "US"],
        "supported_currencies": ["INR", "USD"]
      },
      "body_partial_note": "Only include fields you want to change; omitted fields stay unchanged."
    },
    "payment_settings_get": {
      "method": "GET",
      "path": "/api/v1/admin/integration-settings/payment-settings",
      "response_example": {
        "success": true,
        "message": "success",
        "data": {
          "rows": [{ "_id": "...", "module": "payment", "key": "enable_stripe", "value": "1" }],
          "settings": { "enable_stripe": "1", "payment_option": "cash,card,wallet" }
        }
      }
    },
