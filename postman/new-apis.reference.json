{
  "title": "New APIs reference (admin wallet withdrawals + driver subscriptions)",
  "baseUrl": "/api/v1/admin",
  "authentication": {
    "type": "Bearer",
    "header": "Authorization",
    "value": "Bearer <access_token_from_POST_/api/v1/admin/login>"
  },
  "groups": [
    {
      "name": "Wallet — driver withdrawal summaries",
      "description": "Drivers jinke paas withdrawal request hai (legacy user_id-only rows bhi count).",
      "endpoints": [
        {
          "name": "Drivers with withdrawal requests (list)",
          "method": "GET",
          "path": "/wallet/drivers/withdrawals",
          "queryParams": {
            "page": { "type": "number", "optional": true, "default": 1 },
            "limit": { "type": "number", "optional": true, "default": 20, "max": 100 }
          },
          "responseExample": {
            "success": true,
            "message": "success",
            "data": {
              "results": [
                {
                  "driver_id": "507f1f77bcf86cd799439011",
                  "driver": {
                    "name": "Ravi",
                    "mobile": "9876543210",
                    "email": "ravi@example.com",
                    "owner_id": null
                  },
                  "withdrawal_request_count": 3,
                  "pending_count": 1,
                  "last_request_at": "2026-04-01T10:00:00.000Z"
                }
              ],
              "paginator": {
                "total": 10,
                "per_page": 20,
                "current_page": 1,
                "last_page": 1
              }
            }
          }
        },
        {
          "name": "One driver — all withdrawal requests",
          "method": "GET",
          "path": "/wallet/drivers/:driver_id/withdrawals",
          "pathParams": {
            "driver_id": { "type": "ObjectId", "required": true }
          },
          "queryParams": {
            "page": { "type": "number", "optional": true, "default": 1 },
            "limit": { "type": "number", "optional": true, "default": 20, "max": 100 },
            "status": {
              "type": "string",
              "optional": true,
              "enum": ["requested", "approved", "rejected", "processed"]
            }
          },
          "responseExample": {
            "success": true,
            "message": "success",
            "data": {
              "driver": {
                "_id": "507f1f77bcf86cd799439011",
                "name": "Ravi",
                "mobile": "9876543210",
                "email": "ravi@example.com"
              },
              "results": [
                {
                  "_id": "507f191e810c19729de860ea",
                  "user_id": "507f191e810c19729de860eb",
                  "driver_id": "507f1f77bcf86cd799439011",
                  "owner_id": null,
                  "amount": 500,
                  "requested_currency": "INR",
                  "notes": null,
                  "status": "requested",
                  "processed_at": null,
                  "rejected_reason": null,
                  "payment_reference": null,
                  "createdAt": "2026-04-01T10:00:00.000Z",
                  "updatedAt": "2026-04-01T10:00:00.000Z"
                }
              ],
              "paginator": {
                "total": 2,
                "per_page": 20,
                "current_page": 1,
                "last_page": 1
              }
            }
          }
        }
      ]
    },
    {
      "name": "Driver subscriptions — plans",
      "basePath": "/driver-subscriptions",
      "endpoints": [
        {
          "name": "List plans",
          "method": "GET",
          "path": "/driver-subscriptions/plans/list",
          "queryParams": {
            "page": { "type": "number", "optional": true },
            "limit": { "type": "number", "optional": true },
            "active": { "type": "string", "optional": true, "values": ["0", "1", "true", "false"] },
            "transport_type": { "type": "string", "optional": true, "values": ["taxi", "delivery"] },
            "vehicle_type_id": { "type": "string", "optional": true }
          },
          "responseExample": {
            "success": true,
            "message": "success",
            "data": {
              "results": [
                {
                  "_id": "507f1f77bcf86cd799439011",
                  "name": "Monthly Taxi",
                  "description": "",
                  "transport_type": "taxi",
                  "vehicle_type_id": "sedan",
                  "subscription_duration": 30,
                  "amount": 499,
                  "active": true,
                  "createdAt": "2026-04-01T10:00:00.000Z",
                  "updatedAt": "2026-04-01T10:00:00.000Z"
                }
              ],
              "paginator": {
                "total": 1,
                "per_page": 20,
                "current_page": 1,
                "last_page": 1
              }
            }
          }
        },
        {
          "name": "Create plan",
          "method": "POST",
          "path": "/driver-subscriptions/plans",
          "requestBody": {
            "name": { "type": "string", "required": true },
            "description": { "type": "string", "optional": true },
            "transport_type": { "type": "string", "required": true, "enum": ["taxi", "delivery"] },
            "vehicle_type_id": { "type": "string", "required": true },
            "subscription_duration": { "type": "number", "required": true },
            "amount": { "type": "number", "required": true },
            "active": { "type": "boolean", "optional": true, "default": true }
          },
          "bodyExample": {
            "name": "Monthly Taxi",
            "description": "30 days",
            "transport_type": "taxi",
            "vehicle_type_id": "sedan",
            "subscription_duration": 30,
            "amount": 499,
            "active": true
          },
          "responseExample": {
            "success": true,
            "message": "Created",
            "driver_subscription_plan": {
              "_id": "507f1f77bcf86cd799439011",
              "name": "Monthly Taxi",
              "description": "30 days",
              "transport_type": "taxi",
              "vehicle_type_id": "sedan",
              "subscription_duration": 30,
              "amount": 499,
              "active": true,
              "createdAt": "2026-04-01T10:00:00.000Z",
              "updatedAt": "2026-04-01T10:00:00.000Z"
            }
          }
        },
        {
          "name": "Get plan",
          "method": "GET",
          "path": "/driver-subscriptions/plans/:id",
          "pathParams": { "id": { "type": "ObjectId", "required": true } },
          "responseExample": {
            "success": true,
            "message": "success",
            "data": {
              "driver_subscription_plan": {
                "_id": "507f1f77bcf86cd799439011",
                "name": "Monthly Taxi",
                "description": "",
                "transport_type": "taxi",
                "vehicle_type_id": "sedan",
                "subscription_duration": 30,
                "amount": 499,
                "active": true
              }
            }
          }
        },
        {
          "name": "Update plan",
          "method": "PATCH",
          "path": "/driver-subscriptions/plans/:id",
          "pathParams": { "id": { "type": "ObjectId", "required": true } },
          "requestBody": {
            "name": { "type": "string", "optional": true },
            "description": { "type": "string", "optional": true },
            "transport_type": { "type": "string", "optional": true, "enum": ["taxi", "delivery"] },
            "vehicle_type_id": { "type": "string", "optional": true },
            "subscription_duration": { "type": "number", "optional": true },
            "amount": { "type": "number", "optional": true },
            "active": { "type": "boolean", "optional": true }
          },
          "bodyExample": { "amount": 599, "active": true }
        },
        {
          "name": "Delete plan",
          "method": "DELETE",
          "path": "/driver-subscriptions/plans/:id",
          "pathParams": { "id": { "type": "ObjectId", "required": true } },
          "responseExample": {
            "success": true,
            "message": "Deleted",
            "data": { "id": "507f1f77bcf86cd799439011" }
          }
        }
      ]
    },
    {
      "name": "Driver subscriptions — driver records",
      "endpoints": [
        {
          "name": "List subscriptions",
          "method": "GET",
          "path": "/driver-subscriptions",
          "queryParams": {
            "page": { "type": "number", "optional": true },
            "limit": { "type": "number", "optional": true },
            "driver_id": { "type": "ObjectId", "optional": true },
            "active": { "type": "string", "optional": true, "values": ["0", "1", "true", "false"] }
          },
          "responseExample": {
            "success": true,
            "message": "success",
            "data": {
              "results": [
                {
                  "_id": "507f1f77bcf86cd799439012",
                  "driver_id": {
                    "_id": "507f1f77bcf86cd799439011",
                    "name": "Ravi",
                    "mobile": "9876543210",
                    "email": "ravi@example.com",
                    "owner_id": null
                  },
                  "subscription_detail_id": "507f1f77bcf86cd799439013",
                  "active": true,
                  "starts_at": "2026-04-01T00:00:00.000Z",
                  "ends_at": "2026-05-01T00:00:00.000Z",
                  "amount": 499,
                  "currency": "INR",
                  "createdAt": "2026-04-01T10:00:00.000Z",
                  "updatedAt": "2026-04-01T10:00:00.000Z"
                }
              ],
              "paginator": {
                "total": 1,
                "per_page": 20,
                "current_page": 1,
                "last_page": 1
              }
            }
          }
        },
        {
          "name": "Create subscription",
          "method": "POST",
          "path": "/driver-subscriptions",
          "requestBody": {
            "driver_id": { "type": "ObjectId", "required": true },
            "subscription_detail_id": { "type": "ObjectId", "optional": true },
            "active": { "type": "boolean", "optional": true, "default": true },
            "starts_at": { "type": "ISO8601 date", "optional": true },
            "ends_at": { "type": "ISO8601 date", "optional": true },
            "amount": { "type": "number", "optional": true },
            "currency": { "type": "string", "optional": true }
          },
          "bodyExample": {
            "driver_id": "507f1f77bcf86cd799439011",
            "subscription_detail_id": "507f1f77bcf86cd799439013",
            "active": true,
            "starts_at": "2026-04-01T00:00:00.000Z",
            "ends_at": "2026-05-01T00:00:00.000Z",
            "amount": 499,
            "currency": "INR"
          },
          "responseExample": {
            "success": true,
            "message": "Created",
            "driver_subscription": {
              "_id": "507f1f77bcf86cd799439012",
              "driver_id": "507f1f77bcf86cd799439011",
              "subscription_detail_id": "507f1f77bcf86cd799439013",
              "active": true,
              "starts_at": "2026-04-01T00:00:00.000Z",
              "ends_at": "2026-05-01T00:00:00.000Z",
              "amount": 499,
              "currency": "INR",
              "createdAt": "2026-04-01T10:00:00.000Z",
              "updatedAt": "2026-04-01T10:00:00.000Z"
            }
          }
        },
        {
          "name": "Get subscription",
          "method": "GET",
          "path": "/driver-subscriptions/:id",
          "pathParams": { "id": { "type": "ObjectId", "required": true } },
          "responseExample": {
            "success": true,
            "message": "success",
            "data": {
              "driver_subscription": {
                "_id": "507f1f77bcf86cd799439012",
                "driver_id": {
                  "_id": "507f1f77bcf86cd799439011",
                  "name": "Ravi",
                  "mobile": "9876543210",
                  "email": "ravi@example.com",
                  "owner_id": null
                },
                "subscription_detail_id": "507f1f77bcf86cd799439013",
                "active": true,
                "amount": 499,
                "currency": "INR"
              }
            }
          }
        },
        {
          "name": "Update subscription",
          "method": "PATCH",
          "path": "/driver-subscriptions/:id",
          "pathParams": { "id": { "type": "ObjectId", "required": true } },
          "requestBody": {
            "driver_id": { "type": "ObjectId", "optional": true },
            "subscription_detail_id": { "type": "ObjectId|null", "optional": true },
            "active": { "type": "boolean", "optional": true },
            "starts_at": { "type": "ISO8601 date|null", "optional": true },
            "ends_at": { "type": "ISO8601 date|null", "optional": true },
            "amount": { "type": "number", "optional": true },
            "currency": { "type": "string|null", "optional": true }
          },
          "bodyExample": { "active": false, "ends_at": "2026-04-15T00:00:00.000Z" }
        },
        {
          "name": "Delete subscription",
          "method": "DELETE",
          "path": "/driver-subscriptions/:id",
          "pathParams": { "id": { "type": "ObjectId", "required": true } },
          "responseExample": {
            "success": true,
            "message": "Deleted",
            "data": { "id": "507f1f77bcf86cd799439012" }
          }
        }
      ]
    },
    {
      "name": "Needed documents — extended POST body (same routes)",
      "note": "Routes pehle se /api/v1/admin/owner-management/* par hain; sirf body fields extend hue.",
      "endpoints": [
        {
          "name": "Create driver needed document",
          "method": "POST",
          "path": "/owner-management/driver-needed-document",
          "bodyExample": {
            "name": "Aadhar card",
            "description": "",
            "doc_type": null,
            "document_for": "both",
            "account_type": "both",
            "has_identify_number": false,
            "has_expiry_date": false,
            "identify_number_locale_key": "",
            "image_type": "front_and_back",
            "is_editable": false,
            "document_name_front": "Aadhar front",
            "document_name_back": "Aadhar Back",
            "active": true,
            "is_required": true
          }
        },
        {
          "name": "Create owner needed document",
          "method": "POST",
          "path": "/owner-management/owner-needed-document",
          "note": "account_type DB mein store nahi hota; document_for + baaki fields.",
          "bodyExample": {
            "name": "PAN",
            "description": "",
            "document_for": "both",
            "has_identify_number": true,
            "has_expiry_date": false,
            "identify_number_locale_key": "pan_number",
            "image_type": "single",
            "is_editable": true,
            "document_name_front": "PAN front",
            "document_name_back": "",
            "active": true,
            "is_required": true
          }
        },
        {
          "name": "Create fleet needed document",
          "method": "POST",
          "path": "/owner-management/fleet-needed-document",
          "note": "account_type DB mein store nahi hota.",
          "bodyExample": {
            "name": "RC",
            "description": "",
            "document_for": "fleet",
            "has_identify_number": false,
            "has_expiry_date": true,
            "image_type": "single",
            "document_name_front": "RC",
            "active": true,
            "is_required": true
          }
        }
      ]
    }
  ]
}
